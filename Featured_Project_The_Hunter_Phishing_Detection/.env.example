# ==============================================================
# The Hunter - Environment Variables
# ==============================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit the .env file to version control.
#
# For Google Colab: Add these as Colab Secrets (key icon in the
# left sidebar) and toggle "Notebook access" on for each key.
# ==============================================================

# ---- Groq API (free tier) ----
# Powers LLaMA 3 8B inference for all three CrewAI agents.
# Sign up at: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# ---- Kaggle Credentials ----
# Required to download the Alam Phishing Email Dataset
# and the Cratchley Email Phishing Dataset via kagglehub.
# Find your credentials at: https://www.kaggle.com/settings
KAGGLE_USERNAME=your_kaggle_username_here
KAGGLE_KEY=your_kaggle_api_key_here
